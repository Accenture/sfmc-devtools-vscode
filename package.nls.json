    "command.when.delete": "sfmc-devtools-vscode.config.isproject && resourcePath =~ /\\\\retrieve\\\\[^\\\\]+\\\\[^\\\\]+\\\\[^\\\\]+\\\\([^\\\\]+.(json|jsonc|html|sql|ssjs|md|amp|txt)|[^\\\\]+\\\\)/",
    "command.when.deploy": "sfmc-devtools-vscode.config.isproject && (resourcePath =~ /\\\\deploy\\\\[^\\\\]+\\\\[^\\\\]+\\\\[^\\\\]+/ || (resourcePath =~ /\\\\retrieve\\\\[^\\\\]+\\\\[^\\\\]+\\\\[^\\\\]+\\\\([^\\\\]+.(json|jsonc|html|sql|ssjs|md|amp|txt)|[^\\\\]+\\\\)/))",
    "command.when.retrieve": "sfmc-devtools-vscode.config.isproject && resourcePath =~ /\\\\retrieve\\\\/"
