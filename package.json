		"keybindings": [
			{
				"command": "sfmc-devtools-vscode.retrieve",
				"key": "ctrl+shift+r",
				"mac": "cmd+shift+r",
				"when": "sfmc-devtools-vscode.config.isproject"
			},
			{
				"command": "sfmc-devtools-vscode.deploy",
				"key": "ctrl+shift+d",
				"mac": "cmd+shift+d",
				"when": "sfmc-devtools-vscode.config.isproject"
			},
			{
				"command": "sfmc-devtools-vscode.delete",
				"key": "ctrl+shift+backspace",
				"mac": "cmd+shift+backspace",
				"when": "sfmc-devtools-vscode.config.isproject"
			}
		],
		"configuration": {
			"title": "SFMC DevTools",
			"properties": {
				"sfmc-devtools-vscode.recommendExtensions": {
					"type": "boolean",
					"default": true,
					"description": "Indicates if recommended extensions popup should be shown to user or not."
				},
				"sfmc-devtools-vscode.warnOnMissingJsonRelation": {
					"type": "boolean",
					"default": true,
					"description": "When enabled, shows inline warnings in the Problems panel for unresolvable r__TYPE_key relation fields in JSON metadata files, and offers a quick fix to retrieve the missing item."
				},
				"sfmc-devtools-vscode.contentBlockGoToDefinition": {
					"type": "boolean",
					"default": true,
					"description": "When enabled, ContentBlockByKey() references in files inside the retrieve/ and deploy/ folders become Ctrl+Click links that navigate to the corresponding asset file."
				},
				"sfmc-devtools-vscode.warnOnContentBlockByKey": {
					"type": "boolean",
					"default": true,
					"description": "When enabled, shows inline warnings in the Problems panel for unresolvable ContentBlockByKey() references in files inside the retrieve/ and deploy/ folders, and offers a quick fix to retrieve the missing content block."
				},
				"sfmc-devtools-vscode.warnOnMissingSqlDataExtension": {
					"type": "boolean",
					"default": true,
					"description": "When enabled, shows warning diagnostics for data extension names in SQL query files that cannot be resolved in the retrieve tree, with a quick fix to retrieve them."
				},
				"sfmc-devtools-vscode.warnOnMissingScriptDataExtension": {
					"type": "boolean",
					"default": true,
					"description": "When enabled, shows warning diagnostics for data extension names in SSJS / AMPscript function calls (.amp, .ssjs, .html, .js files) that cannot be resolved in the retrieve tree, with a quick fix to retrieve them."
				},
				"sfmc-devtools-vscode.showSqlDataViewHoverNotice": {
					"type": "boolean",
					"default": true,
					"description": "When enabled, shows hover-only informational hints for known SFMC system data views (e.g. _Sent, _Open) in SQL query files."
				},
				"sfmc-devtools-vscode.showTreeView": {
					"type": "boolean",
					"default": false,
					"markdownDescription": "**[BETA]** When enabled, shows the SFMC DevTools Explorer tree view in the Activity Bar for browsing Credentials, Business Units, and metadata types. This feature is under construction."
				}
			}
		},
		"walkthroughs": [
			{
				"id": "sfmc-devtools-vscode.gettingStarted",
				"title": "Get Started with SFMC DevTools",
				"description": "Set up your Salesforce Marketing Cloud development environment.",
				"steps": [
					{
						"id": "installMcdev",
						"title": "Install mcdev",
						"description": "Install the mcdev CLI tool globally via npm.\n\n[Open Terminal](command:workbench.action.terminal.new)",
						"media": {
							"markdown": "docs/walkthrough/install.md"
						},
						"completionEvents": [
							"onCommand:sfmc-devtools-vscode.restartExtension"
						]
					},
					{
						"id": "createInstalledPackage",
						"title": "Create SFMC Installed Package",
						"description": "Create a Server-to-Server Installed Package in your SFMC account for API authentication.",
						"media": {
							"markdown": "docs/walkthrough/installed-package.md"
						}
					},
					{
						"id": "initProject",
						"title": "Initialize Project",
						"description": "Run mcdev init to set up your project with credentials and configuration.\n\n[Initialize Project](command:sfmc-devtools-vscode.init)",
						"media": {
							"markdown": "docs/walkthrough/init.md"
						},
						"completionEvents": [
							"onCommand:sfmc-devtools-vscode.init"
						]
					},
					{
						"id": "firstRetrieve",
						"title": "Retrieve Your First BU",
						"description": "Right-click on a Business Unit folder in the Explorer and select 'mcdev: Retrieve' to download metadata.",
						"media": {
							"markdown": "docs/walkthrough/retrieve.md"
						},
						"completionEvents": [
							"onCommand:sfmc-devtools-vscode.retrieve"
						]
					},
					{
						"id": "exploreDiagnostics",
						"title": "Explore Diagnostics & Links",
						"description": "Open retrieved files to see inline diagnostics, clickable links, and quick fixes powered by SFMC DevTools.",
						"media": {
							"markdown": "docs/walkthrough/diagnostics.md"
						}
					}
				]
			}
		],
		"jsonValidation": [
			{
				"fileMatch": ".mcdevrc.json",
				"url": "./schemas/mcdevrc.schema.json"
			}
		]
	},
	"scripts": {
		"webpack": "webpack --mode development",
		"webpack-dev": "webpack --mode development --watch",
		"vscode:prepublish": "npm run package",
		"compile": "webpack",
		"watch": "webpack --watch",
		"package": "webpack --mode production --devtool hidden-source-map",
		"package:test": "npx @vscode/vsce package --pre-release -o sfmc-devtools-vscode-BETA.vsix",
		"package:release": "npx @vscode/vsce package",
		"deploy": "vsce publish",
		"lint": "eslint ./src --ext .ts",
		"test": "npm run lint && npm run test:unit",
		"test:unit": "cross-env TS_NODE_PROJECT=tsconfig.test.json mocha",
		"lint:fix": "eslint --fix ./src --ext .ts",
		"lint-ts": "tsc -p tsconfig.npmScripts.json",
		"prepare": "husky",
		"prepare-release:audit-fix": "npm audit fix",
		"prepare-release:git": "node prepare-release.js",
		"prepare-release": "run-s --continue-on-error prepare-release:audit-fix lint:fix prepare-release:git",
		"version:major": "npm version --no-commit-hooks major",
		"version:minor": "npm version --no-commit-hooks minor",
		"version:patch": "npm version --no-commit-hooks patch"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.5.0",
		"@types/vscode": "^1.109.0",
		"@typescript-eslint/parser": "^8.58.1",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/vsce": "^3.7.1",
		"cross-env": "^10.1.0",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-prettier": "5.5.5",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"mocha": "^11.7.5",
		"npm-run-all": "^4.1.5",
		"ovsx": "^0.10.10",
		"prettier": "3.8.1",
		"ts-loader": "^9.5.4",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.0",
		"webpack": "^5.105.4",
		"webpack-cli": "^6.0.1"
	},
	"dependencies": {
		"@vscode/codicons": "^0.0.45"
	},
	"lint-staged": {
		"*.js": "eslint --fix",
		"*.ts": "eslint --fix --ext .ts"
	}
}
