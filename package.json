{
	"name": "sfmc-devtools-vscode",
	"displayName": "SFMC DevTools",
	"description": "Unofficial IDE for Salesforce Marketing Cloud - Handle and manipulate several SFMC assets (journeys, automations, queries, SSJS, AMPScript, etc..) between your local machine and Salesforce Marketing Cloud (SFMC).",
	"version": "2.3.0",
	"license": "MIT",
	"publisher": "Accenture-oss",
	"repository": {
		"type": "git",
		"url": "https://github.com/Accenture/sfmc-devtools-vscode.git"
	},
	"icon": "resources/images/sfmc-devtools-logo.jpg",
	"engines": {
		"vscode": "^1.109.0"
	},
	"peerDependencies": {
		"mcdev": ">=9.0.0"
	},
	"keywords": [
		"amp",
		"ampscript",
		"business units",
		"content builder",
		"deployment",
		"developer",
		"devops",
		"exacttarget",
		"extension",
		"ide",
		"marketing cloud",
		"mc",
		"package manager",
		"salesforce",
		"server-side javascript",
		"sfmc",
		"ssjs",
		"vscode"
	],
	"categories": [
		"Other"
	],
	"main": "./dist/extension.bundle.js",
	"activationEvents": [
		"onStartupFinished"
	],
	"contributes": {
		"commands": [
			{
				"command": "sfmc-devtools-vscode.copytobu",
				"title": "%command.title.copytobu%"
			},
			{
				"command": "sfmc-devtools-vscode.delete",
				"title": "%command.title.delete%"
			},
			{
				"command": "sfmc-devtools-vscode.deploy",
				"title": "%command.title.deploy%"
			},
			{
				"command": "sfmc-devtools-vscode.restartExtension",
				"title": "%command.title.restartExtension%"
			},
			{
				"command": "sfmc-devtools-vscode.retrieve",
				"title": "%command.title.retrieve%"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "sfmc-devtools-vscode.copytobu",
					"when": "%command.when.copytobu%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.delete",
					"when": "%command.when.delete%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.deploy",
					"when": "%command.when.deploy%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.restartExtension",
					"when": "sfmc-devtools-vscode.config.isproject",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.retrieve",
					"when": "%command.when.retrieve%",
					"group": "devtools"
				}
			],
			"editor/context": [
				{
					"command": "sfmc-devtools-vscode.copytobu",
					"when": "%command.when.copytobu%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.delete",
					"when": "%command.when.delete%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.deploy",
					"when": "%command.when.deploy%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.retrieve",
					"when": "%command.when.retrieve%",
					"group": "devtools"
				}
			],
			"explorer/context": [
				{
					"command": "sfmc-devtools-vscode.copytobu",
					"when": "%command.when.copytobu%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.delete",
					"when": "%command.when.delete%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.deploy",
					"when": "%command.when.deploy%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.retrieve",
					"when": "%command.when.retrieve%",
					"group": "devtools"
				}
			],
			"editor/title/context": [
				{
					"command": "sfmc-devtools-vscode.copytobu",
					"when": "%command.when.copytobu%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.delete",
					"when": "%command.when.delete%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.deploy",
					"when": "%command.when.deploy%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.retrieve",
					"when": "%command.when.retrieve%",
					"group": "devtools"
				}
			]
		},
		"configuration": {
			"title": "SFMC DevTools",
			"properties": {
				"sfmc-devtools-vscode.recommendExtensions": {
					"type": "boolean",
					"default": true,
					"description": "Indicates if recommended extensions popup should be shown to user or not."
				}
			}
		}
	},
	"scripts": {
		"webpack": "webpack --mode development",
		"webpack-dev": "webpack --mode development --watch",
		"vscode:prepublish": "npm run package",
		"compile": "webpack",
		"watch": "webpack --watch",
		"package": "webpack --mode production --devtool hidden-source-map",
		"package:test-vsix": "npx @vscode/vsce package --pre-release -o sfmc-devtools-vscode-test.vsix",
		"package:release": "npx @vscode/vsce package",
		"deploy": "vsce publish",
		"lint": "eslint src --ext ts",
		"test": "npm run lint",
		"lint:fix": "eslint --fix src --ext ts",
		"lint-ts": "tsc -p tsconfig.npmScripts.json",
		"prepare": "husky",
		"prepare-release:audit-fix": "npm audit fix",
		"prepare-release:git": "node prepare-release.js",
		"prepare-release": "run-s --continue-on-error prepare-release:audit-fix lint:fix prepare-release:git",
		"version:major": "npm version --no-commit-hooks major",
		"version:minor": "npm version --no-commit-hooks minor",
		"version:patch": "npm version --no-commit-hooks patch"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^9.39.4",
		"@types/node": "^25.3.5",
		"@types/vscode": "^1.109.0",
		"@typescript-eslint/parser": "^8.56.1",
		"@vscode/vsce": "^3.7.1",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-prettier": "5.5.5",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.3",
		"prettier": "3.8.1",
		"ts-loader": "^9.5.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"webpack": "^5.105.4",
		"webpack-cli": "^6.0.1"
	},
	"dependencies": {
		"@vscode/codicons": "^0.0.44"
	},
	"lint-staged": {
		"*.js": [
			"eslint --fix --ext ts"
		]
	}
}
