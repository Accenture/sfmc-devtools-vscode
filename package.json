{
	"name": "sfmc-devtools-vscode",
	"displayName": "SFMC DevTools",
	"description": "Unofficial IDE for Salesforce Marketing Cloud - Handle and manipulate several SFMC assets (journeys, automations, queries, SSJS, AMPScript, etc..) between your local machine and Salesforce Marketing Cloud (SFMC).",
	"version": "2.6.0",
	"license": "MIT",
	"publisher": "Accenture-oss",
	"repository": {
		"type": "git",
		"url": "https://github.com/Accenture/sfmc-devtools-vscode.git"
	},
	"icon": "resources/images/sfmc-devtools-logo2.png",
	"engines": {
		"vscode": "^1.109.0"
	},
	"peerDependencies": {
		"mcdev": ">=9.0.0"
	},
	"keywords": [
		"amp",
		"ampscript",
		"business units",
		"content builder",
		"deployment",
		"developer",
		"devops",
		"exacttarget",
		"extension",
		"ide",
		"marketing cloud",
		"mc",
		"mcdev",
		"package manager",
		"salesforce",
		"server-side javascript",
		"sfmc",
		"ssjs",
		"vscode"
	],
	"categories": [
		"Other"
	],
	"main": "./dist/extension.bundle.js",
	"activationEvents": [
		"onStartupFinished"
	],
	"contributes": {
		"commands": [
			{
				"command": "sfmc-devtools-vscode.changekey",
				"title": "%command.title.changekey%"
			},
			{
				"command": "sfmc-devtools-vscode.copytobu",
				"title": "%command.title.copytobu%"
			},
			{
				"command": "sfmc-devtools-vscode.delete",
				"title": "%command.title.delete%"
			},
			{
				"command": "sfmc-devtools-vscode.deploy",
				"title": "%command.title.deploy%"
			},
			{
				"command": "sfmc-devtools-vscode.restartExtension",
				"title": "%command.title.restartExtension%"
			},
			{
				"command": "sfmc-devtools-vscode.retrieve",
				"title": "%command.title.retrieve%"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "sfmc-devtools-vscode.changekey",
					"when": "%command.when.changekey%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.copytobu",
					"when": "%command.when.copytobu%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.delete",
					"when": "%command.when.delete%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.deploy",
					"when": "%command.when.deploy%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.restartExtension",
					"when": "sfmc-devtools-vscode.config.isproject",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.retrieve",
					"when": "%command.when.retrieve%",
					"group": "devtools"
				}
			],
			"editor/context": [
				{
					"command": "sfmc-devtools-vscode.changekey",
					"when": "%command.when.changekey%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.copytobu",
					"when": "%command.when.copytobu%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.delete",
					"when": "%command.when.delete%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.deploy",
					"when": "%command.when.deploy%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.retrieve",
					"when": "%command.when.retrieve%",
					"group": "devtools"
				}
			],
			"explorer/context": [
				{
					"command": "sfmc-devtools-vscode.changekey",
					"when": "%command.when.changekey%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.copytobu",
					"when": "%command.when.copytobu%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.delete",
					"when": "%command.when.delete%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.deploy",
					"when": "%command.when.deploy%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.retrieve",
					"when": "%command.when.retrieve%",
					"group": "devtools"
				}
			],
			"editor/title/context": [
				{
					"command": "sfmc-devtools-vscode.changekey",
					"when": "%command.when.changekey%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.copytobu",
					"when": "%command.when.copytobu%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.delete",
					"when": "%command.when.delete%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.deploy",
					"when": "%command.when.deploy%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.retrieve",
					"when": "%command.when.retrieve%",
					"group": "devtools"
				}
			]
		},
		"configuration": {
			"title": "SFMC DevTools",
			"properties": {
				"sfmc-devtools-vscode.recommendExtensions": {
					"type": "boolean",
					"default": true,
					"description": "Indicates if recommended extensions popup should be shown to user or not."
				},
				"sfmc-devtools-vscode.warnOnMissingJsonRelation": {
					"type": "boolean",
					"default": true,
					"description": "When enabled, shows inline warnings in the Problems panel for unresolvable r__TYPE_key relation fields in JSON metadata files, and offers a quick fix to retrieve the missing item."
				},
				"sfmc-devtools-vscode.warnOnContentBlockByKey": {
					"type": "boolean",
					"default": true,
					"description": "When enabled, shows inline warnings in the Problems panel for unresolvable ContentBlockByKey() references in files inside the retrieve/ and deploy/ folders, and offers a quick fix to retrieve the missing content block."
				},
				"sfmc-devtools-vscode.warnOnMissingSqlDataExtension": {
					"type": "boolean",
					"default": true,
					"description": "When enabled, shows warning diagnostics for data extension names in SQL query files that cannot be resolved in the retrieve tree, with a quick fix to retrieve them."
				},
				"sfmc-devtools-vscode.warnOnMissingScriptDataExtension": {
					"type": "boolean",
					"default": true,
					"description": "When enabled, shows warning diagnostics for data extension names in SSJS / AMPscript function calls (.amp, .ssjs, .html, .js files) that cannot be resolved in the retrieve tree, with a quick fix to retrieve them."
				},
				"sfmc-devtools-vscode.showSqlDataViewHoverNotice": {
					"type": "boolean",
					"default": true,
					"description": "When enabled, shows hover-only informational hints for known SFMC system data views (e.g. _Sent, _Open) in SQL query files."
				}
			}
		}
	},
	"scripts": {
		"webpack": "webpack --mode development",
		"webpack-dev": "webpack --mode development --watch",
		"vscode:prepublish": "npm run package",
		"compile": "webpack",
		"watch": "webpack --watch",
		"package": "webpack --mode production --devtool hidden-source-map",
		"package:test-vsix": "npx @vscode/vsce package --pre-release -o sfmc-devtools-vscode-test.vsix",
		"package:release": "npx @vscode/vsce package",
		"deploy": "vsce publish",
		"lint": "eslint ./src --ext .ts",
		"test": "npm run lint && npm run test:unit",
		"test:unit": "cross-env TS_NODE_PROJECT=tsconfig.test.json mocha",
		"lint:fix": "eslint --fix ./src --ext .ts",
		"lint-ts": "tsc -p tsconfig.npmScripts.json",
		"prepare": "husky",
		"prepare-release:audit-fix": "npm audit fix",
		"prepare-release:git": "node prepare-release.js",
		"prepare-release": "run-s --continue-on-error prepare-release:audit-fix lint:fix prepare-release:git",
		"version:major": "npm version --no-commit-hooks major",
		"version:minor": "npm version --no-commit-hooks minor",
		"version:patch": "npm version --no-commit-hooks patch"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.3.5",
		"@types/vscode": "^1.109.0",
		"@typescript-eslint/parser": "^8.57.2",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/vsce": "^3.7.1",
		"cross-env": "^10.1.0",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-prettier": "5.5.5",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"mocha": "^11.7.5",
		"npm-run-all": "^4.1.5",
		"prettier": "3.8.1",
		"ts-loader": "^9.5.4",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"webpack": "^5.105.4",
		"webpack-cli": "^6.0.1"
	},
	"dependencies": {
		"@vscode/codicons": "^0.0.44"
	},
	"lint-staged": {
		"*.js": "eslint --fix",
		"*.ts": "eslint --fix --ext .ts"
	}
}
