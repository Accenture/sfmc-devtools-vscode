					"when": "%command.when.changekey%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.copytobu",
					"when": "%command.when.copytobu%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.execute",
					"when": "%command.when.execute%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.schedule",
					"when": "%command.when.schedule%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.pause",
					"when": "%command.when.pause%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.stop",
					"when": "%command.when.stop%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.publish",
					"when": "%command.when.publish%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.validate",
					"when": "%command.when.validate%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.refresh",
					"when": "%command.when.refresh%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.build",
					"when": "%command.when.build%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.createDeltaPkg",
					"when": "sfmc-devtools-vscode.config.isproject",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.fixKeys",
					"when": "%command.when.fixKeys%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.init",
					"when": "sfmc-devtools-vscode.config.isproject",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.join",
					"when": "sfmc-devtools-vscode.config.isproject",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.reloadBUs",
					"when": "sfmc-devtools-vscode.config.isproject",
					"group": "devtools"
				},
				{
