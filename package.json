			},
			{
				"command": "sfmc-devtools-vscode.init",
				"title": "%command.title.init%",
				"icon": "$(new-folder)"
			},
			{
				"command": "sfmc-devtools-vscode.join",
				"title": "%command.title.join%",
				"icon": "$(repo-clone)"
			},
			{
				"command": "sfmc-devtools-vscode.reloadBUs",
				"title": "%command.title.reloadBUs%",
				"icon": "$(sync)"
			},
			{
				"command": "sfmc-devtools-vscode.upgrade",
				"title": "%command.title.upgrade%",
				"icon": "$(arrow-up)"
			},
			{
				"command": "sfmc-devtools-vscode.restartExtension",
				"title": "%command.title.restartExtension%",
				"icon": "$(debug-restart)"
			},
			{
				"command": "sfmc-devtools-vscode.showWhatsNew",
				"title": "%command.title.showWhatsNew%"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "sfmc-devtools-vscode.retrieve",
					"when": "%command.when.retrieve%",
					"group": "devtools"
				},
				{
					"command": "sfmc-devtools-vscode.deploy",
					"when": "%command.when.deploy%",
					"group": "devtools"
				},
				{
