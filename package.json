				"icon": "$(rocket)"
			},
			{
				"command": "sfmc-devtools-vscode.validate",
				"title": "%command.title.validate%",
				"icon": "$(check)"
			},
			{
				"command": "sfmc-devtools-vscode.refresh",
				"title": "%command.title.refresh%",
				"icon": "$(refresh)"
			},
			{
				"command": "sfmc-devtools-vscode.build",
				"title": "%command.title.build%",
				"icon": "$(package)"
			},
			{
				"command": "sfmc-devtools-vscode.createDeltaPkg",
				"title": "%command.title.createDeltaPkg%",
				"icon": "$(git-compare)"
			},
			{
				"command": "sfmc-devtools-vscode.fixKeys",
				"title": "%command.title.fixKeys%",
