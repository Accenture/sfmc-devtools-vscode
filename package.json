{
	"name": "sfmc-devtools-vscode",
	"displayName": "SFMC DevTools",
	"description": "Unofficial IDE for Salesforce Marketing Cloud - Handle and manipulate several SFMC assets (journeys, automations, queries, SSJS, AMPScript, etc..) between your local machine and Salesforce Marketing Cloud (SFMC).",
	"version": "3.1.2",
	"license": "MIT",
	"publisher": "Accenture-oss",
	"repository": {
		"type": "git",
		"url": "https://github.com/Accenture/sfmc-devtools-vscode.git"
	},
	"icon": "resources/images/sfmc-devtools-logo2.png",
	"engines": {
		"vscode": "^1.109.0"
	},
	"peerDependencies": {
		"mcdev": ">=9.0.0"
	},
	"keywords": [
		"amp",
		"ampscript",
		"business units",
		"content builder",
		"deployment",
		"developer",
		"devops",
		"exacttarget",
		"extension",
		"ide",
		"marketing cloud",
		"mc",
		"mcdev",
		"package manager",
		"salesforce",
		"server-side javascript",
		"sfmc",
		"ssjs",
		"vscode"
	],
	"categories": [
		"Other"
	],
	"main": "./dist/extension.bundle.js",
    "extensionPack": [
        "dbaeumer.vscode-eslint",
        "editorconfig.editorconfig",
        "esbenp.prettier-vscode",
        "joernberkefeld.sfmc-language",
        "joernberkefeld.sfmc-data"
    ],
	"activationEvents": [
		"onStartupFinished"
	],
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "sfmc-devtools",
					"title": "SFMC DevTools",
					"icon": "resources/images/sfmc-devtools-logo2.png"
				}
			]
		},
		"views": {
			"sfmc-devtools": [
				{
					"id": "sfmc-devtools-vscode.explorer",
					"name": "Explorer",
					"icon": "resources/images/sfmc-devtools-logo2.png",
					"when": "sfmc-devtools-vscode.config.isproject && sfmc-devtools-vscode.config.showTreeView"
				}
			]
		},
		"submenus": [
			{
				"id": "sfmc-devtools-vscode.submenu",
				"label": "SFMC DevTools"
			}
		],
		"commands": [
			{
				"command": "sfmc-devtools-vscode.retrieve",
				"title": "%command.title.retrieve%",
				"icon": "$(cloud-download)"
			},
			{
				"command": "sfmc-devtools-vscode.deploy",
				"title": "%command.title.deploy%",
				"icon": "$(cloud-upload)"
			},
			{
				"command": "sfmc-devtools-vscode.delete",
